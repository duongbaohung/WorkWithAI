<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BTEC FPT Edu"
        android:layout_gravity="center_horizontal"
        android:textSize="18sp"
        android:textStyle="bold|italic"/>
    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/bteclogo"
        android:layout_marginTop="10dp"
        android:layout_gravity="center_horizontal"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Profile"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:weightSum="4">
        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/profilepic"
            android:layout_marginEnd="10dp"
            android:layout_gravity="center_horizontal"
            android:layout_weight="1"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:layout_weight="3">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name: John Doe"
                android:textSize="20sp"
                android:textStyle="italic"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email: jd@gmail.com"
                android:textSize="20sp"
                android:textStyle="italic"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone: 123456789"
                android:textSize="20sp"
                android:textStyle="italic"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address: 4th Avenue, NY"
                android:textSize="20sp"
                android:textStyle="italic"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Biography:"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="start"
        android:layout_marginTop="50dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="John Doe (born John Nommensen Duchac on February 25, 1953) is an influential American singer, songwriter, and actor. He is best known as the co-founder of the seminal Los Angeles punk rock band X."
        android:textSize="18sp"
        android:textStyle="italic"
        android:layout_gravity="fill_horizontal"
        android:layout_marginTop="10dp"/>

</LinearLayout>